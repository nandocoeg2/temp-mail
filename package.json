{
  "name": "dropmail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:build": "npm run test && npm run build",
    "test:e2e": "playwright test",
