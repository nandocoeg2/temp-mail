    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.11.11",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "dotenv": "^17.4.2",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "pg": "^8.13.1",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
