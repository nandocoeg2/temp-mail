{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dropmail-email-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-04-26",
  "workers_dev": false,
  "preview_urls": false,
  "vars": {
    "APP_INBOUND_URL": "https://fjulian.space/api/inbound/email",
    "MAX_EMAIL_BYTES": "8388608"
  },
  "secrets": {
    "required": ["INBOUND_WEBHOOK_SECRET"]
  }
}
